<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>BlackIce.Tools.MapExtractor</RootNamespace>
    <AssemblyName>MapExtractor</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AssetsTools.NET" Version="3.0.4" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reuse the server's BNAV format / NavMesh type so the tool never duplicates the on-disk format. -->
    <ProjectReference Include="..\..\server\BlackIce.Server.Core\BlackIce.Server.Core.csproj" />
  </ItemGroup>

</Project>
