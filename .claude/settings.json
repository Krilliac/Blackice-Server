{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".claude/hooks/guard_leak.py"],
            "timeout": 15,
            "statusMessage": "Leak-guard: checking for game-derived material..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".claude/hooks/format_cs.py"],
            "async": true,
            "timeout": 120,
            "statusMessage": "dotnet format..."
          }
        ]
      }
    ]
  }
}
