# ---- BlackIce.Server .gitignore ----
# Build output
bin/
obj/
[Bb]uild/

# Game-derived or secret material — NEVER commit (see CLAUDE.md, NOTICE, SECURITY.md).
# This is the primary (and only) leak guard: a normal `git add` / `git add -A` will never
# stage these. Do NOT `git add -f` a path below — that deliberately bypasses this guard.
decompiled/
captures/
asset-dumps/
third-party/
Black Ice_Data/
*.dll
*.exe
*.pdb
oplog.jsonl
steam-ticket-spike.log
*.db
*.db-shm
*.db-wal
blackice.server.json

# Dev environment
.remember/
.vs/
.idea/
*.user

# Local memory (not for public repo)
memory/
*.local.json
